{
  "manifest_version": 3,
  "name": "Phishing Detector & Blocker",
  "version": "1.0",
  "description": "Real-time protection against phishing sites",

  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  }
}